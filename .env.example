NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: policy-safe display ads for Free users only (never on billing, EPK, embeds, admin, campaign flows).
# NEXT_PUBLIC_ADS_ENABLED=true
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=1234567890
# Per-placement slots (optional): NEXT_PUBLIC_ADSENSE_SLOT_ARTIST_MID, _ARTIST_FOOTER, _SONG_FOOTER, _DISCOVER, _DASHBOARD
# Optional: Desktop workspace sidebar (Phase 50A). Set to 1 to enable by default; users can override via localStorage key viatone_workspace_sidebar_v1.
# NEXT_PUBLIC_WORKSPACE_SIDEBAR_V1=1
# Optional: Global desktop sidebar navigation (Phase 54B). Set to 1 to enable; override via localStorage key viatone_sidebar_nav_v1 or ?sidebar=1 on any authenticated route.
# NEXT_PUBLIC_SIDEBAR_NAV_V1=1

OPENAI_API_KEY=your-openai-api-key
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Last.fm API key for playlist campaign scrobble proof import (https://www.last.fm/api/account/create)
# LASTFM_API_KEY=your-lastfm-api-key
# Optional: Resend API key for forwarding studio-page contact form submissions to email.
# Get one free at https://resend.com (3000 emails/month free tier).
# RESEND_API_KEY=re_...
# RESEND_FROM=ViaTone <onboarding@resend.dev>   # default if unset; verified domain recommended for production

# Optional: fal.ai API key for AI video (Canvas) generation via Seedance Pro.
# Get one at https://fal.ai. ~$0.10–0.30 per video.
# FAL_KEY=...
# FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1/pro/text-to-video   # override text-to-video model path
# FAL_VIDEO_I2V_MODEL=fal-ai/bytedance/seedance/v1/pro/image-to-video   # override image-to-video model path
