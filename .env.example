NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Optional: Resend API key for forwarding studio-page contact form submissions to email.
# Get one free at https://resend.com (3000 emails/month free tier).
# RESEND_API_KEY=re_...
# RESEND_FROM=Songcraft <onboarding@resend.dev>   # default if unset; verified domain recommended for production

# Optional: fal.ai API key for AI video (Canvas) generation via Seedance Pro.
# Get one at https://fal.ai. ~$0.10–0.30 per video.
# FAL_KEY=...
# FAL_VIDEO_MODEL=fal-ai/bytedance/seedance-1-pro/text-to-video   # override default model path if needed
